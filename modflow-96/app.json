{
  "id": "modflow-96-simulation",
  "version": "0.0.1",
  "description": "Run a MODFLOW-96 simulation on TACC using a cookbook-style Tapis application.",
  "owner": "${apiUserId}",
  "enabled": true,
  "runtime": "SINGULARITY",
  "runtimeVersion": null,
  "runtimeOptions": [
    "SINGULARITY_RUN"
  ],
  "containerImage": "docker://ghcr.io/wmobley/modflow-96:0.0.1",
  "jobType": "BATCH",
  "maxJobs": -1,
  "maxJobsPerUser": -1,
  "strictFileInputs": false,
  "jobAttributes": {
    "description": null,
    "dynamicExecSystem": false,
    "execSystemConstraints": null,
    "execSystemId": "ls6",
    "execSystemExecDir": "${JobWorkingDir}",
    "execSystemInputDir": "${JobWorkingDir}",
    "execSystemOutputDir": "${JobWorkingDir}/output",
    "execSystemLogicalQueue": "vm-small",
    "archiveSystemId": "cloud.data",
    "archiveSystemDir": "HOST_EVAL($HOME)/tapis-jobs-archive/${JobCreateDate}/${JobName}-${JobUUID}",
    "archiveOnAppError": true,
    "isMpi": false,
    "mpiCmd": null,
    "cmdPrefix": "mkdir $PWD/work $PWD/home $PWD/scratch;",
    "parameterSet": {
      "appArgs": [
        {
          "arg": "/corral-repl/tacc/aci/PT2050/projects/PTDATAX-272/workingGAMs/Trinity_hill_country/Trinity_hill_country_model_only/modfl_96/ststate",
          "name": "mf96DefaultDir",
          "description": "Default baseline MODFLOW-96 input directory used when files are not present in uploaded inputs.",
          "inputMode": "FIXED",
          "notes": {
            "isHidden": true
          }
        }
      ],
      "schedulerOptions": [
        {
          "name": "TACC Scheduler Profile",
          "description": "Scheduler profile for HPC clusters at TACC",
          "inputMode": "FIXED",
          "arg": "--tapis-profile tacc-apptainer",
          "notes": {
            "isHidden": true
          }
        },
        {
          "name": "TAP Session Substring",
          "description": "TAP Functions require the substring 'tap_' and in the slurm job name in order to function.",
          "inputMode": "FIXED",
          "arg": "--job-name ${JobName}-tap_",
          "notes": {
            "isHidden": true
          }
        }
      ],
      "envVariables": [],
      "archiveFilter": {
        "includes": [],
        "excludes": [],
        "includeLaunchFiles": true
      }
    },
    "fileInputs": [
      {
        "name": "mf96-simulation-archive",
        "description": "Optional ZIP archive containing a MODFLOW-96 simulation or supporting files.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "simulation.zip"
      },
      {
        "name": "mf96-nam",
        "description": "Optional MODFLOW-96 name file. If omitted, the app will resolve the best available *.nam file from staged inputs.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.nam"
      },
      {
        "name": "mf96-bas",
        "description": "Optional BAS package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/bas.dat"
      },
      {
        "name": "mf96-bcf",
        "description": "Optional BCF package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/bcf.dat"
      },
      {
        "name": "mf96-discret",
        "description": "Optional discretization file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/discret.dat"
      },
      {
        "name": "mf96-drn",
        "description": "Optional DRN package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/drn.dat"
      },
      {
        "name": "mf96-ghb",
        "description": "Optional GHB package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/ghb.dat"
      },
      {
        "name": "mf96-oc",
        "description": "Optional output control file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/oc.dat"
      },
      {
        "name": "mf96-output",
        "description": "Optional output control companion file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/output.dat"
      },
      {
        "name": "mf96-rch",
        "description": "Optional RCH package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/rch.dat"
      },
      {
        "name": "mf96-riv",
        "description": "Optional RIV package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/riv.dat"
      },
      {
        "name": "mf96-sor",
        "description": "Optional SOR solver file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/sor.dat"
      },
      {
        "name": "mf96-wel",
        "description": "Optional WEL package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/wel.dat"
      }
    ],
    "fileInputArrays": [],
    "nodeCount": 1,
    "coresPerNode": 1,
    "memoryMB": 1000,
    "maxMinutes": 60,
    "subscriptions": [],
    "tags": []
  },
  "tags": [
    "portalName: ALL"
  ],
  "notes": {
    "label": "MODFLOW-96",
    "helpUrl": "https://github.com/In-For-Disaster-Analytics/Cookbook-Docker-Template",
    "helpText": "Provide either a simulation ZIP or any subset of MODFLOW-96 input files. The launch script stages those files under provided/, fills missing files from the configured baseline directory, resolves the best available *.nam file, and runs MODFLOW-96.",
    "hideNodeCountAndCoresPerNode": true,
    "isInteractive": false,
    "icon": "jupyter",
    "category": "Data Processing",
    "queueFilter": [
      "vm-small",
      "development",
      "normal"
    ]
  }
}
