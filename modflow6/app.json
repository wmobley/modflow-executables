    "fileInputArrays": [],
    "nodeCount": 1,
    "coresPerNode": 1,
    "memoryMB": 1000,
    "maxMinutes": 60,
    "subscriptions": [],
    "tags": []
  },
  "tags": [
    "portalName: ALL"
  ],
  "notes": {
    "label": "MODFLOW 6",
    "helpUrl": "https://www.simonwenkel.com/notes/geo/software/modflow/compiling-modflow-on-linux.html",
    "helpText": "Provide either a simulation ZIP or any subset of MF6 input files. The launch script stages those files under provided/, fills missing files from the configured baseline directory, and generates mfsim.nam and a model name file when they are not supplied.",
    "hideNodeCountAndCoresPerNode": true,
    "isInteractive": false,
    "icon": "jupyter",
    "category": "Data Processing",
    "queueFilter": [
      "vm-small",
      "development",
      "normal"
    ]
  }
}
