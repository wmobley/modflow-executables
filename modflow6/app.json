{
  "id": "modflow6-simulation",
  "version": "0.0.239861d",
  "description": "Run a MODFLOW 6 simulation on TACC using the MODFLOW 6 binary built inside the container image.",
  "owner": "${apiUserId}",
  "enabled": true,
  "runtime": "SINGULARITY",
  "runtimeVersion": null,
  "runtimeOptions": [
    "SINGULARITY_RUN"
  ],
  "containerImage": "docker://ghcr.io/wmobley/modflow6:sha-239861d",
  "jobType": "BATCH",
  "maxJobs": -1,
  "maxJobsPerUser": -1,
  "strictFileInputs": false,
  "jobAttributes": {
    "description": null,
    "dynamicExecSystem": false,
    "execSystemConstraints": null,
    "execSystemId": "ls6",
    "execSystemExecDir": "${JobWorkingDir}",
    "execSystemInputDir": "${JobWorkingDir}",
    "execSystemOutputDir": "${JobWorkingDir}/output",
    "execSystemLogicalQueue": "vm-small",
    "archiveSystemId": "cloud.data",
    "archiveSystemDir": "HOST_EVAL($HOME)/tapis-jobs-archive/${JobCreateDate}/${JobName}-${JobUUID}",
    "archiveOnAppError": true,
    "isMpi": false,
    "mpiCmd": null,
    "cmdPrefix": "mkdir $PWD/work $PWD/home $PWD/scratch;",
    "parameterSet": {
      "appArgs": [
        {
          "arg": "__NONE__",
          "name": "mf6DefaultDir",
          "description": "Default baseline MF6 input directory used when files are not present in uploaded inputs.",
          "inputMode": "FIXED",
          "notes": {
            "isHidden": true
          }
        }
      ],
      "schedulerOptions": [
        {
          "name": "TACC Scheduler Profile",
          "description": "Scheduler profile for HPC clusters at TACC",
          "inputMode": "FIXED",
          "arg": "--tapis-profile tacc-apptainer",
          "notes": {
            "isHidden": true
          }
        },
        {
          "name": "TAP Session Substring",
          "description": "TAP Functions require the substring 'tap_' and in the slurm job name in order to function.",
          "inputMode": "FIXED",
          "arg": "--job-name ${JobName}-tap_",
          "notes": {
            "isHidden": true
          }
        },
        {
          "name": "TACC Allocation",
          "description": "TACC allocation charged for MODFLOW jobs.",
          "inputMode": "FIXED",
          "arg": "-A PT2050-DataX",
          "notes": {
            "isHidden": true
          }
        }
      ],
      "envVariables": [],
      "archiveFilter": {
        "includes": [],
        "excludes": [],
        "includeLaunchFiles": true
      }
    },
    "fileInputs": [
      {
        "name": "mf6-simulation-archive",
        "description": "Optional ZIP archive containing a MODFLOW 6 simulation or supporting files such as array data.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "simulation.zip"
      },
      {
        "name": "mf6-sim-nam",
        "description": "Optional simulation name file. If omitted, the app will generate mfsim.nam from the staged MF6 inputs.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/mfsim.nam"
      },
      {
        "name": "mf6-model-nam",
        "description": "Optional groundwater flow model name file. If omitted, the app will generate one from the staged package inputs.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.nam"
      },
      {
        "name": "mf6-tdis",
        "description": "Optional TDIS file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/simulation.tdis"
      },
      {
        "name": "mf6-ims",
        "description": "Optional IMS solver file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/simulation.ims"
      },
      {
        "name": "mf6-dis",
        "description": "Optional DIS package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.dis"
      },
      {
        "name": "mf6-disv",
        "description": "Optional DISV package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.disv"
      },
      {
        "name": "mf6-disu",
        "description": "Optional DISU package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.disu"
      },
      {
        "name": "mf6-ic",
        "description": "Optional initial conditions file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.ic"
      },
      {
