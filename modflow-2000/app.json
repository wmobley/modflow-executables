{
  "id": "modflow-2000-simulation",
  "version": "0.0.3335c94",
  "description": "Run a MODFLOW-2000 simulation on TACC using a cookbook-style Tapis application.",
  "owner": "${apiUserId}",
  "enabled": true,
  "runtime": "SINGULARITY",
  "runtimeVersion": null,
  "runtimeOptions": [
    "SINGULARITY_RUN"
  ],
  "containerImage": "docker://ghcr.io/wmobley/modflow-2000:sha-3335c94",
  "jobType": "BATCH",
  "maxJobs": -1,
  "maxJobsPerUser": -1,
  "strictFileInputs": false,
  "jobAttributes": {
    "description": null,
    "dynamicExecSystem": false,
    "execSystemConstraints": null,
    "execSystemId": "ls6",
    "execSystemExecDir": "${JobWorkingDir}",
    "execSystemInputDir": "${JobWorkingDir}",
    "execSystemOutputDir": "${JobWorkingDir}/output",
    "execSystemLogicalQueue": "vm-small",
    "archiveSystemId": "cloud.data",
    "archiveSystemDir": "HOST_EVAL($HOME)/tapis-jobs-archive/${JobCreateDate}/${JobName}-${JobUUID}",
    "archiveOnAppError": true,
    "isMpi": false,
    "mpiCmd": null,
    "cmdPrefix": "mkdir $PWD/work $PWD/home $PWD/scratch;",
    "parameterSet": {
      "appArgs": [
        {
          "arg": "/corral-repl/tacc/aci/PT2050/projects/PTDATAX-272/workingGAMs/Yequa_Jackson/Yegua_Jackson_Model_Only/CD-2_ygjk_model/Modflow_2000",
          "name": "mf2000DefaultDir",
          "description": "Default baseline MODFLOW-2000 input directory used when files are not present in uploaded inputs.",
          "inputMode": "FIXED",
          "notes": {
            "isHidden": true
          }
        }
      ],
      "schedulerOptions": [
        {
          "name": "TACC Scheduler Profile",
          "description": "Scheduler profile for HPC clusters at TACC",
          "inputMode": "FIXED",
          "arg": "--tapis-profile tacc-apptainer",
          "notes": {
            "isHidden": true
          }
        },
        {
          "name": "TAP Session Substring",
          "description": "TAP Functions require the substring 'tap_' and in the slurm job name in order to function.",
          "inputMode": "FIXED",
          "arg": "--job-name ${JobName}-tap_",
          "notes": {
            "isHidden": true
          }
        },
        {
          "name": "TACC Allocation",
          "description": "TACC allocation charged for MODFLOW jobs.",
          "inputMode": "FIXED",
          "arg": "-A PT2050-DataX",
          "notes": {
            "isHidden": true
          }
        }
      ],
      "envVariables": [],
      "archiveFilter": {
        "includes": [],
        "excludes": [],
        "includeLaunchFiles": true
      }
    },
    "fileInputs": [
      {
        "name": "mf2000-simulation-archive",
        "description": "Optional ZIP archive containing a MODFLOW-2000 simulation or supporting files.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "simulation.zip"
      },
      {
        "name": "mf2000-nam",
        "description": "Optional MODFLOW-2000 name file. If omitted, the app will resolve the best available *.nam file from staged inputs.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.nam"
      },
      {
        "name": "mf2000-bas",
        "description": "Optional BAS package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.bas"
      },
      {
        "name": "mf2000-bcf",
        "description": "Optional BCF package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.bcf"
      },
      {
        "name": "mf2000-dis",
        "description": "Optional DIS package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.dis"
      },
      {
        "name": "mf2000-drn",
        "description": "Optional DRN package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.drn"
      },
      {
        "name": "mf2000-evt",
        "description": "Optional EVT package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.evt"
      },
      {
        "name": "mf2000-ghb",
        "description": "Optional GHB package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.ghb"
      },
      {
        "name": "mf2000-gmg",
        "description": "Optional GMG solver file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.gmg"
      },
      {
        "name": "mf2000-oc",
        "description": "Optional output control file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.oc"
      },
      {
        "name": "mf2000-rch",
        "description": "Optional RCH package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.rch"
      },
      {
        "name": "mf2000-str",
        "description": "Optional STR package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.str"
      },
      {
        "name": "mf2000-wel",
        "description": "Optional WEL package file.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "provided/model.wel"
      }
    ],
    "fileInputArrays": [],
    "nodeCount": 1,
    "coresPerNode": 1,
    "memoryMB": 1000,
    "maxMinutes": 60,
    "subscriptions": [],
    "tags": []
  },
  "tags": [
    "portalName: ALL"
  ],
  "notes": {
    "label": "MODFLOW-2000",
    "helpUrl": "https://github.com/In-For-Disaster-Analytics/Cookbook-Docker-Template",
    "helpText": "Provide either a simulation ZIP or any subset of MODFLOW-2000 input files. The launch script stages those files under provided/, fills missing files from the configured baseline directory, resolves the best available *.nam file, and runs MODFLOW-2000.",
    "hideNodeCountAndCoresPerNode": true,
    "isInteractive": false,
    "icon": "jupyter",
    "category": "Data Processing",
    "queueFilter": [
      "vm-small",
      "development",
      "normal"
    ]
  }
}
