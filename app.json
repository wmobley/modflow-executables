{
  "id": "modflow6-simulation",
  "version": "0.0.905bb64",
  "description": "Run a MODFLOW 6 simulation on TACC using the MODFLOW 6 binary built inside the container image.",
  "owner": "${apiUserId}",
  "enabled": true,
  "runtime": "SINGULARITY",
  "runtimeVersion": null,
  "runtimeOptions": [
    "SINGULARITY_RUN"
  ],
  "containerImage": "docker://ghcr.io/wmobley/modflow6:sha-905bb64",
  "jobType": "BATCH",
  "maxJobs": -1,
  "maxJobsPerUser": -1,
  "strictFileInputs": false,
  "jobAttributes": {
    "description": null,
    "dynamicExecSystem": false,
    "execSystemConstraints": null,
    "execSystemId": "ls6",
    "execSystemExecDir": "${JobWorkingDir}",
    "execSystemInputDir": "${JobWorkingDir}",
    "execSystemOutputDir": "${JobWorkingDir}/output",
    "execSystemLogicalQueue": "vm-small",
    "archiveSystemId": "cloud.data",
    "archiveSystemDir": "HOST_EVAL($HOME)/tapis-jobs-archive/${JobCreateDate}/${JobName}-${JobUUID}",
    "archiveOnAppError": true,
    "isMpi": false,
    "mpiCmd": null,
    "cmdPrefix": "mkdir $PWD/work $PWD/home $PWD/scratch;",
    "parameterSet": {
      "appArgs": [],
      "schedulerOptions": [
        {
          "name": "TACC Scheduler Profile",
          "description": "Scheduler profile for HPC clusters at TACC",
          "inputMode": "FIXED",
          "arg": "--tapis-profile tacc-apptainer",
          "notes": {
            "isHidden": true
          }
        },
        {
          "name": "TAP Session Substring",
          "description": "TAP Functions require the substring 'tap_' and in the slurm job name in order to function.",
          "inputMode": "FIXED",
          "arg": "--job-name ${JobName}-tap_",
          "notes": {
            "isHidden": true
          }
        }
      ],
      "envVariables": [
        {
          "key": "MF6_NAM_URL",
          "value": "__REQUIRED_NAM_URL__",
          "description": "Direct CKAN download URL for the MF6 simulation name file (typically mfsim.nam).",
          "inputMode": "REQUIRED",
          "notes": {}
        },
        {
          "key": "MF6_WEL_URL",
          "value": "__NONE__",
          "description": "Direct CKAN download URL for the replacement WEL package file. May come from a different dataset.",
          "inputMode": "REQUIRED",
          "notes": {}
        },
        {
          "key": "MF6_RCH_URL",
          "value": "__NONE__",
          "description": "Direct CKAN download URL for the replacement RCH/RCHA package file. May come from a different dataset.",
          "inputMode": "REQUIRED",
          "notes": {}
        }
      ],
      "archiveFilter": {
        "includes": [],
        "excludes": [],
        "includeLaunchFiles": true
      }
    },
    "fileInputs": [
      {
        "name": "gma14-wel",
        "description": "WEL6 package file",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": "tapis://ptdatax.project.PTDATAX-272/twdb_gam_collection/Gulf_Coast_Aquifer_System_northern_portion_GAM_version_4.1/glfc_n_v4_tacc/gma14/gma14.wel",
        "targetPath": "gma14.wel"
      },
      {
        "name": "gma14-rch-oc",
        "description": "RCH6 OC recharge package file",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": "tapis://ptdatax.project.PTDATAX-272/twdb_gam_collection/Gulf_Coast_Aquifer_System_northern_portion_GAM_version_4.1/glfc_n_v4_tacc/gma14/gma14_rch_oc.rcha",
        "targetPath": "gma14_rch_oc.rcha"
      },
      {
        "name": "gma14-rch-sc",
        "description": "RCH6 SC recharge package file",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": "tapis://ptdatax.project.PTDATAX-272/twdb_gam_collection/Gulf_Coast_Aquifer_System_northern_portion_GAM_version_4.1/glfc_n_v4_tacc/gma14/gma14_rch_sc.rcha",
        "targetPath": "gma14_rch_sc.rcha"
      },
      {
        "name": "gma14-default-dir",
        "description": "Default GMA14 input directory (all non-interactive files).",
        "inputMode": "REQUIRED",
        "autoMountLocal": true,
        "sourceUrl": "tapis://ptdatax.project.PTDATAX-272/twdb_gam_collection/Gulf_Coast_Aquifer_System_northern_portion_GAM_version_4.1/glfc_n_v4_tacc/gma14",
        "targetPath": "default_data"
      }
    ],
    "fileInputArrays": [],
    "nodeCount": 1,
    "coresPerNode": 1,
    "memoryMB": 1000,
    "maxMinutes": 60,
    "subscriptions": [],
    "tags": []
  },
  "tags": [
    "portalName: ALL"
  ],
  "notes": {
    "label": "MODFLOW 6",
    "helpUrl": "https://www.simonwenkel.com/notes/geo/software/modflow/compiling-modflow-on-linux.html",
    "helpText": "Provide a CKAN URL to an MF6 name file (mfsim.nam), plus optional CKAN URLs for replacement WEL and RCH files. The app will pull the remaining files from the NAM file dataset and run MF6.",
    "hideNodeCountAndCoresPerNode": true,
    "isInteractive": false,
    "icon": "jupyter",
    "category": "Data Processing",
    "queueFilter": [
      "vm-small",
      "development",
      "normal"
    ]
  }
}
